rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all collections by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /scores_v2/{scoreId} {
      // Public read (leaderboard)
      allow read: if true;

      // Public create with strict field validation
      allow create: if
        request.resource.data.keys().hasAll(['name', 'score', 'time', 'date', 'allFloors']) &&
        request.resource.data.keys().hasOnly(['name', 'score', 'time', 'date', 'allFloors']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 20 &&
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 50000 &&
        request.resource.data.time is number &&
        request.resource.data.time >= 0 &&
        request.resource.data.date is int &&
        request.resource.data.date > 0 &&
        request.resource.data.allFloors is bool;

      allow update, delete: if false;
    }
  }
}
